---
import '../styles/global.css';
import StickySignupBar from '../components/StickySignupBar.astro';
const { title = 'BetterHuman', description = 'Clarity for modern life.', image = '/assets/og-image.svg' } = Astro.props;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <StickySignupBar />
    <header class="site-header">
      <div class="container nav">
        <a class="brand-wrap" href="/">
          <img class="brand-mark" src="/assets/logo.svg" alt="BetterHuman logo" />
          <span><span class="brand">BetterHuman</span><span class="brand-sub">Clarity for modern life</span></span>
        </a>
        <nav>
          <a href="/" class={path === '/' ? 'active' : ''}>Home</a>
          <a href="/blog" class={path.startsWith('/blog') || path.startsWith('/posts') ? 'active' : ''}>Blog</a>
          <a href="/newsletter" class={path.startsWith('/newsletter') ? 'active' : ''}>Newsletter</a>
          <a href="/categories" class={path.startsWith('/categories') ? 'active' : ''}>Categories</a>
          <a href="/about" class={path.startsWith('/about') ? 'active' : ''}>About</a>
          <a href="/contact" class={path.startsWith('/contact') ? 'active' : ''}>Contact</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container footer-grid">
        <div>
          <a class="brand-wrap" href="/">
            <img class="brand-mark" src="/assets/logo.svg" alt="BetterHuman logo" />
            <span><span class="brand">BetterHuman</span><span class="brand-sub">Clarity for modern life</span></span>
          </a>
          <p style="margin-top: 1rem;">A free weekly newsletter about digital health, attention, habits, and better defaults.</p>
        </div>
        <div>
          <h4>Pages</h4>
          <a href="/">Home</a><a href="/blog">Blog</a><a href="/newsletter">Newsletter</a><a href="/categories">Categories</a><a href="/about">About</a><a href="/contact">Contact</a>
        </div>
        <div>
          <h4>Growth</h4>
          <a href="/seo-ideas">SEO ideas</a><a href="/posts/reels-addiction">Reels Addiction</a><a href="/posts/porn-and-compulsive-stimulation">Compulsion</a>
        </div>
        <div>
          <h4>Main goal</h4>
          <p>Get readers onto the free weekly newsletter and monetize with tasteful email ads.</p>
        </div>
      </div>
      <div class="container footer-note">
        <span>Free newsletter first. Trust first. Ads live in the weekly email.</span>
        <span>Astro build for speed, SEO, and content publishing.</span>
      </div>
    </footer>
  </body>
</html>
