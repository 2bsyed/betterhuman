---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thanks — BetterHuman" description="Thanks for joining BetterHuman.">
  <main class="section">
    <div class="container narrow center contact-panel">
      <p class="eyebrow">Thanks</p>
      <h1>You’re in.</h1>
      <p class="lead">Your signup or message was received. BetterHuman is built around giving readers free weekly value in the inbox.</p>
      <div class="hero-actions" style="justify-content:center; margin-top:1.2rem;">
        <a class="btn btn-primary" href="/">Back home</a>
        <a class="btn btn-secondary" href="/blog">Read articles</a>
      </div>
    </div>
  </main>
</BaseLayout>
